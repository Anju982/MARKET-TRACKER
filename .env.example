# Finnhub API Token (Get one at https://finnhub.io/)
FinHubAPI=your_finnhub_token_here

# Google Gemini API Key (Get one at https://aistudio.google.com/)
GEMINI_API_KEY=your_gemini_api_key_here

# Backend URL (Leave as default for single-container deployment)
BACKEND_URL=http://localhost:8000

# CORS Allowed Origins (Comma-separated list of trusted domains)
ALLOWED_ORIGINS=http://localhost:8501
